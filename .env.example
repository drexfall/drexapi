# drexapi (FastAPI + event-sourcing). Copy to .env and fill in.

# --- event store ---
# dev: in-memory sqlite. prod: eventsourcing.postgres (+ POSTGRES_* below)
PERSISTENCE_MODULE=eventsourcing.sqlite
SQLITE_DBNAME=:memory:
# POSTGRES_DBNAME=drexapi
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=drex
# POSTGRES_PASSWORD=

# --- read models (Mongo). empty => in-memory stores (dev only) ---
MONGODB_URI=
MONGO_DB=drexapi

# --- Auth0 ---
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_CLAIMS_NAMESPACE=https://drexapi/
AUTH0_CLIENT_ID=
AUTH0_MGMT_CLIENT_ID=
AUTH0_MGMT_CLIENT_SECRET=

# --- carousel ingest (machine channel) ---
CAROUSEL_INGEST_TOKEN=

# --- carousel render/publish (off => LocalRenderer/FakePublisher) ---
CAROUSEL_REAL_RENDER=false
IMAGEKIT_PRIVATE=
IMAGEKIT_PUBLIC=
IMAGEKIT_URL_ENDPOINT=
MEDIA_ROOT=media
MEDIA_URL=/media/
META_IG_USER_ID=
META_ACCESS_TOKEN=
META_GRAPH_VERSION=v23.0

# --- Celery (async render at scale) ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
